<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    tools:context=".PlaygroundActivity">
    <androidx.core.widget.NestedScrollView
        android:layout_height="0dp"
        android:layout_width="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:padding="24dp">
            <!-- Header Section -->
            <TextView
                style="@style/TextAppearance.Editorial.Display"
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:text="@string/replacement_playground" />
            <TextView
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_width="match_parent"
                android:text="@string/replacement_playground_subtitle"
                android:textColor="@color/onSurfaceVariant" />
            <TextView
                android:id="@+id/no_active_purchase_msg"
                style="@style/TextAppearance.Material3.BodyLarge.Emphasized"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_width="match_parent"
                android:text="@string/trigger_subscription_text"
                android:textColor="@color/primary"
                android:textStyle="bold" />
            <include layout="@layout/active_subscription_card" />
            <TextView
                android:id="@+id/subs_section_header"
                style="@style/TextAppearance.Material3.TitleLarge"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_width="match_parent"
                android:letterSpacing="0.1"
                android:text="@string/replacement_subs" />
            <com.google.android.material.card.MaterialCardView
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                app:cardBackgroundColor="@color/surface_high"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <LinearLayout
                        android:id="@+id/replacement_tiers_container"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:orientation="vertical" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/add_custom_sub_button"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_width="match_parent"
                        android:text="@string/add_custom_subscription"
                        android:textColor="@color/primary_red" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <TextView
                android:id="@+id/replacement_mode_header"
                style="@style/TextAppearance.Material3.TitleLarge"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_width="match_parent"
                android:letterSpacing="0.1"
                android:text="@string/replacement_modes" />
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/replacement_mode_container"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_width="match_parent"
                app:cardBackgroundColor="@color/surface_low"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp">
                <RadioGroup
                    android:id="@+id/replacement_mode_group"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/test_replacement_button"
                style="@style/Widget.Editorial.Button"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_width="match_parent"
                android:text="@string/btn_text_test_replacement"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <include layout="@layout/bottom_navigation" />
</androidx.constraintlayout.widget.ConstraintLayout>
